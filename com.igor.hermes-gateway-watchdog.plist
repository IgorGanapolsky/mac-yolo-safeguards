<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.igor.hermes-gateway-watchdog</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>{{REPO}}/scripts/hermes-gateway-watchdog.sh</string>
    </array>
    <key>RunAtLoad</key><true/>
    <key>StartInterval</key><integer>60</integer>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key><string>{{HOME}}</string>
        <key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HERMES_PIN_MODEL</key><string>{{HERMES_PIN_MODEL}}</string>
    </dict>
    <key>StandardOutPath</key><string>{{HOME}}/Library/Logs/hermes-gateway-watchdog.launchd.log</string>
    <key>StandardErrorPath</key><string>{{HOME}}/Library/Logs/hermes-gateway-watchdog.launchd.log</string>
</dict>
</plist>
