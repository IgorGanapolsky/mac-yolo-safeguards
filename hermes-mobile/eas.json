{
  "cli": {
    "version": ">= 19.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_HERMES_DEV_UNLOCK": "1",
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_HERMES_DEV_UNLOCK": "1",
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "channel": "preview"
    },
    "e2e-test": {
      "withoutCredentials": true,
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_E2E_AUTOMATION": "1",
        "EXPO_PUBLIC_HERMES_DEV_UNLOCK": "1"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "e2e-test"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_POSTHOG_HOST": "https://us.i.posthog.com",
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "channel": "production"
    }
  },
  "update": {
    "production": {
      "channel": "production"
    },
    "preview": {
      "channel": "preview"
    },
    "e2e-test": {
      "channel": "e2e-test"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "$EXPO_ANDROID_SERVICE_ACCOUNT_KEY_PATH",
        "track": "production",
        "releaseStatus": "completed"
      },
      "ios": {
        "ascAppId": "6786778037",
        "appleTeamId": "9GMM26JC5X"
      }
    }
  }
}
