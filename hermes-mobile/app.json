{
  "expo": {
    "name": "Hermes Mobile",
    "slug": "hermes-mobile",
    "scheme": "hermes",
    "experiments": {
      "reactCompiler": true
    },
    "version": "0.3.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F19"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.iganapolsky.hermesmobile",
      "userInterfaceStyle": "dark",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundImage": "./assets/adaptive-background.png",
        "monochromeImage": "./assets/adaptive-monochrome.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.iganapolsky.hermesmobile",
      "versionCode": 5,
      "userInterfaceStyle": "dark",
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "4ed13e30-9b97-4ddd-8a12-59106cae90d6"
      }
    },
    "owner": "igorganapolsky",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/4ed13e30-9b97-4ddd-8a12-59106cae90d6"
    },
    "plugins": [
      "./plugins/withEmbeddedJsBundle.js",
      "./plugins/withHermesAiGlasses.js",
      "./plugins/withHermesAppleIntelligence.js",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "softwareKeyboardLayoutMode": "resize",
            "buildArchs": ["arm64-v8a"],
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "# Play Billing (expo-iap)\n-keep class com.android.billingclient.api.** { *; }\n-dontwarn com.android.billingclient.api.**\n# ML Kit barcode + libbarhopper (expo-camera QR scanner)\n-keep class com.google.mlkit.** { *; }\n-keep class com.google.android.gms.internal.mlkit_vision_** { *; }\n-keep class com.google.android.libraries.barhopper.** { *; }\n-keep class com.google.android.gms.vision.** { *; }\n-dontwarn com.google.mlkit.**\n-dontwarn com.google.android.gms.internal.mlkit_vision_**\n# react-native-reanimated (ships no consumer rules)\n-keep class com.swmansion.reanimated.** { *; }\n-keep class com.swmansion.gesturehandler.** { *; }\n# JNI / reflection native methods safety net\n-keepclasseswithmembernames class * { native <methods>; }"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Scan the Hermes pairing QR shown on your computer."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366F1"
        }
      ],
      "expo-iap"
    ]
  }
}
