{
  "name": "hermes-mobile",
  "version": "0.1.0",
  "description": "Hermes mobile companion \u2014 ThumbGate approvals, gateway health, YOLO safeguard telemetry",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "bash ./scripts/run-android-safe.sh",
    "android:phone": "bash ./scripts/install-phone-release.sh",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest --watchman=false",
    "test:ci": "jest --runInBand --coverage --watchman=false",
    "test:release-safety": "jest --runInBand --watchman=false src/__tests__/apkReleaseGuards.test.ts src/__tests__/releaseSafetyContract.test.ts src/__tests__/internalDistributionWorkflow.test.ts",
    "verify:apk": "bash ./scripts/verify-apk-package.sh",
    "e2e:device": "bash ./scripts/run-device-e2e.sh",
    "doctor:expo": "node ./scripts/run-expo-doctor.cjs",
    "release:check": "node ./scripts/verify-release-readiness.cjs",
    "release:check:json": "node ./scripts/verify-release-readiness.cjs --json",
    "eas:usage": "npx eas-cli account:usage",
    "eas:build:guard": "node ./scripts/eas-build-guard.cjs",
    "launch:preflight:android": "npm run release:check && bash ./scripts/release-preflight.sh android",
    "launch:preflight:ios": "npm run release:check && bash ./scripts/release-preflight.sh ios",
    "launch:preflight:all": "npm run release:check && bash ./scripts/release-preflight.sh all",
    "e2e:validate": "node scripts/validate-maestro-flows.js",
    "e2e": "bash ./scripts/run-e2e.sh",
    "e2e:all": "bash ./scripts/run-e2e.sh",
    "e2e:simulator": "bash ./scripts/run-simulator-e2e.sh",
    "e2e:simulator:flow": "bash ./scripts/run-simulator-e2e.sh",
    "e2e:android:device": "bash ./scripts/run-e2e.sh",
    "e2e:continuous": "bash ./scripts/run-continuous-e2e.sh --daemon",
    "e2e:continuous:once": "bash ./scripts/run-continuous-e2e.sh --once",
    "e2e:continuous:watch": "bash ./scripts/run-continuous-e2e.sh --watch",
    "e2e:continuous:stop": "bash ./scripts/run-continuous-e2e.sh --stop",
    "e2e:continuous:status": "bash ./scripts/verify-continuous-e2e.sh",
    "e2e:ship-guard": "bash ./scripts/run-e2e.sh .maestro/ship-guard.yaml",
    "e2e:android": "maestro test .maestro/",
    "e2e:ios": "maestro test .maestro/",
    "e2e:accelerated": "bash ./scripts/run-agent-device-e2e.sh",
    "test:e2e:accelerated": "npm run e2e:accelerated",
    "analyze:bundle": "bash ./scripts/analyze-bundle.sh android",
    "analyze:bundle:ios": "bash ./scripts/analyze-bundle.sh ios",
    "perf:flashlight": "command -v flashlight >/dev/null && flashlight --help || echo 'Install Flashlight CLI: npm i -g @bam.tech/flashlight'",
    "e2e:fast": "agent-device test --maestro .maestro/",
    "e2e:fast:android": "agent-device test --maestro .maestro/ --platform android",
    "e2e:fast:ios": "agent-device test --maestro .maestro/ --platform ios",
    "device": "agent-device help workflow",
    "device:rn": "agent-device help react-native",
    "devtools:rozenite": "rozenite dev",
    "devtools:rozenite-agent": "rozenite agent",
    "ota:preview": "eas update --channel preview --environment preview",
    "ota:e2e": "eas update --channel e2e-test --environment preview",
    "ota:production": "eas update --channel production --environment production",
    "test:perf": "reassure"
  },
  "dependencies": {
    "@react-native-ai/dev-tools": "^0.12.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@shopify/flash-list": "2.0.2",
    "expo": "~55.0.27",
    "expo-build-properties": "~55.0.15",
    "expo-camera": "~55.0.20",
    "expo-constants": "~55.0.16",
    "expo-haptics": "~55.0.15",
    "expo-iap": "^4.3.1",
    "expo-notifications": "~55.0.24",
    "expo-secure-store": "~55.0.15",
    "expo-splash-screen": "~55.0.22",
    "expo-store-review": "~55.0.15",
    "expo-updates": "~55.0.25",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "use-context-selector": "^2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "19.1.0",
    "agent-device": "^0.16.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "babel-preset-expo": "~55.0.0",
    "expo-doctor": "^1.17.3",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.1",
    "react-test-renderer": "19.2.0",
    "reassure": "^1.5.1",
    "rozenite": "^1.10.0",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "js-yaml": "^4.2.0",
    "uuid": "^11.1.1"
  }
}
