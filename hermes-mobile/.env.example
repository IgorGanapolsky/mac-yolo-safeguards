# Hermes Mobile — EAS / release env (mirrored from ../LipoShield/.env.example).
# Copy to .env and fill values, or run: ../../scripts/mirror-liposhield-secrets.sh

EXPO_TOKEN=

# Android Play submit (file path on your Mac)
EXPO_ANDROID_SERVICE_ACCOUNT_KEY_PATH=/absolute/path/to/google-play-service-account.json

# iOS App Store Connect submit (same Apple team as LipoShield)
EXPO_ASC_APP_ID=
EXPO_ASC_API_KEY_ID=
EXPO_ASC_API_KEY_ISSUER_ID=
EXPO_ASC_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXX.p8
EXPO_APPLE_TEAM_ID=9GMM26JC5X
EXPO_APPLE_ID=
EXPO_APPLE_APP_SPECIFIC_PASSWORD=

# Firebase internal Android distro (optional — only if using android_firebase target)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_ANDROID_APP_ID=
FIREBASE_REQUIRED_TESTER_EMAIL=
FIREBASE_INTERNAL_GROUPS=internal-testers
FIREBASE_INTERNAL_TESTERS=
