# Hermes Mobile — EAS / release env
# Copy to .env and fill values, or run: ../../scripts/sync-hermes-secrets.sh

EXPO_TOKEN=

# Android Play Console API (LLC organization account — NOT Firebase)
# Play Console → Setup → API access → service account JSON
EXPO_ANDROID_SERVICE_ACCOUNT_KEY_PATH=/absolute/path/to/play-org-api-sa.json

# iOS App Store Connect submit (Apple ID — not the Android/Firebase Gmail)
EXPO_ASC_APP_ID=
EXPO_ASC_API_KEY_ID=
EXPO_ASC_API_KEY_ISSUER_ID=
EXPO_ASC_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXX.p8
EXPO_APPLE_TEAM_ID=9GMM26JC5X
EXPO_APPLE_ID=igor.ganapolsky@icloud.com
EXPO_APPLE_APP_SPECIFIC_PASSWORD=

# Firebase internal Android distro (iganapolsky@gmail.com — not the iCloud Apple ID)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_ANDROID_APP_ID=
FIREBASE_REQUIRED_TESTER_EMAIL=iganapolsky@gmail.com
FIREBASE_INTERNAL_GROUPS=internal-testers
FIREBASE_INTERNAL_TESTERS=
