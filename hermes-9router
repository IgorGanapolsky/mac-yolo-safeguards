#!/usr/bin/env node
'use strict';

const fs = require('fs');
const os = require('os');
const path = require('path');

function resolveHarness() {
  const candidates = [
    path.resolve(__dirname, 'tools', 'hermes-9router-harness.js'),
    path.join(os.homedir(), '.hermes', '9router', 'tools', 'hermes-9router-harness.js'),
  ];
  const target = candidates.find((candidate) => fs.existsSync(candidate));
  if (!target) throw new Error('Hermes 9Router harness is missing');
  return require(target);
}

async function main(argv = process.argv.slice(2)) {
  try {
    const harness = resolveHarness();
    if (argv.length === 0) return harness.main(['--help']);
    if (argv.includes('--doctor')) {
      return harness.main(argv.filter((arg) => arg !== '--doctor'));
    }
    if (argv.includes('--help') || argv.includes('-h')) return harness.main(argv);
    return harness.main(['--execute', ...argv]);
  } catch (error) {
    console.error(`hermes-9router: ${String(error.message).slice(0, 300)}`);
    return 2;
  }
}

if (require.main === module) {
  main().then((code) => { process.exitCode = code; });
}

module.exports = { main, resolveHarness };
