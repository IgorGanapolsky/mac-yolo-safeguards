#!/usr/bin/env bash
# Pre-commit guard for hermes-mobile — catches regressions before they reach CI.
# Enable once per clone/worktree:  git config core.hooksPath .githooks
#   (or run: scripts/install-git-hooks.sh)
# Bypass in an emergency with: git commit --no-verify
set -euo pipefail

# Only act when hermes-mobile TS/TSX is staged (skip docs/asset/other commits).
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^hermes-mobile/.*\.(ts|tsx)$' || true)
[ -z "$staged" ] && exit 0

echo "▶ pre-commit: hermes-mobile typecheck + targeted tests…"
cd hermes-mobile

# 1) Typecheck — would have caught type-level breaks before CI.
if ! npm run --silent typecheck; then
  echo "✗ typecheck failed — commit blocked (use --no-verify to override)"
  exit 1
fi

# 2) Run only the tests related to the staged files (fast; full suite + coverage run in CI).
# --runInBand avoids cross-suite pollution (ChatScreen scroll spies + open handles).
files=$(echo "$staged" | sed 's#^hermes-mobile/##' | tr '\n' ' ')
if ! npx jest --bail --runInBand --findRelatedTests $files --passWithNoTests --watchman=false; then
  echo "✗ related tests failed — commit blocked (use --no-verify to override)"
  exit 1
fi

echo "✓ pre-commit passed"
