#!/usr/bin/env bash
# ibm-yolo — Enterprise multi-agent SDLC reliability operator
#
# Named for the IBM Bob-class market shift (full-lifecycle agents, cost/governance),
# NOT an IBM product. Runs the mac-yolo-safeguards enterprise-sdlc cash path:
# market signal → Stripe-verified CTAs → pipeline seed → optional smart-ops.
#
# Usage:
#   ibm-yolo                  # enterprise-sdlc signal + apply pipeline + summary
#   ibm-yolo --json           # machine-readable
#   ibm-yolo --doctor         # health: repo tools, stripe, launchagents
#   ibm-yolo --no-apply       # drafts only (no pipeline write)
#   ibm-yolo --smart-ops      # also run smart-ops controller once
#   ibm-yolo --both           # hermes-hosted + enterprise-sdlc presets
#   ibm-yolo --help

set -euo pipefail

HOME_DIR="${HOME}"
# Same layout family as grok-yolo / meta-yolo / hermes-yolo:
#   ~/.hermes/ibm-bob/          runtime home (tools + this CLI)
#   ~/.local/bin/ibm-yolo       symlink → ~/.hermes/ibm-bob/ibm-yolo
HERMES_HOME="${IBM_YOLO_HOME:-$HOME_DIR/.hermes/ibm-bob}"
WORKSPACE_REPO="$HOME_DIR/workspace/git/igor/mac-yolo-safeguards"
MAIN_RUNTIME="$WORKSPACE_REPO/.worktrees/main-runtime"

resolve_repo() {
  if [[ -n "${IBM_YOLO_REPO:-}" && -f "${IBM_YOLO_REPO}/tools/hermes-hosting-market-signal.js" ]]; then
    printf '%s\n' "$IBM_YOLO_REPO"
    return
  fi
  if [[ -f "$HERMES_HOME/tools/hermes-hosting-market-signal.js" ]]; then
    printf '%s\n' "$HERMES_HOME"
    return
  fi
  if [[ -f "$MAIN_RUNTIME/tools/hermes-hosting-market-signal.js" ]]; then
    printf '%s\n' "$MAIN_RUNTIME"
    return
  fi
  if [[ -f "$WORKSPACE_REPO/tools/hermes-hosting-market-signal.js" ]]; then
    printf '%s\n' "$WORKSPACE_REPO"
    return
  fi
  printf '%s\n' "$HERMES_HOME"
}

REPO="$(resolve_repo)"
export REVENUE_DIR="${REVENUE_DIR:-$WORKSPACE_REPO/business_os/revenue}"
export PATH="${HOME_DIR}/.local/bin:/opt/homebrew/bin:/usr/local/bin:${PATH:-}"

JSON=0
DOCTOR=0
APPLY=1
SMART=0
BOTH=0
HELP=0

usage() {
  cat <<'EOF'
ibm-yolo — Enterprise multi-agent SDLC reliability (IBM Bob-class market signal)

  ibm-yolo                 Run enterprise-sdlc market signal (apply pipeline)
  ibm-yolo --json          JSON output
  ibm-yolo --doctor        Health check only
  ibm-yolo --no-apply      Do not write pipeline
  ibm-yolo --smart-ops     Chain smart-ops after signal
  ibm-yolo --both          hermes-hosted + enterprise-sdlc presets
  ibm-yolo --help

Env:
  IBM_YOLO_HOME    runtime home (default ~/.hermes/ibm-bob)
  IBM_YOLO_REPO    override tools root (default: hermes home, then main-runtime)
  REVENUE_DIR      private business_os/revenue path

Install (same pattern as grok-yolo / meta-yolo):
  bash scripts/install-ibm-yolo.sh
  # → ~/.hermes/ibm-bob/* + ~/.local/bin/ibm-yolo symlink
EOF
}

while (($#)); do
  case "$1" in
    --json) JSON=1; shift ;;
    --doctor) DOCTOR=1; shift ;;
    --no-apply) APPLY=0; shift ;;
    --smart-ops) SMART=1; shift ;;
    --both) BOTH=1; shift ;;
    -h|--help) HELP=1; shift ;;
    *)
      echo "ibm-yolo: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if ((HELP)); then
  usage
  exit 0
fi

if [[ ! -f "$REPO/tools/hermes-hosting-market-signal.js" ]]; then
  echo "ibm-yolo: market-signal tool missing at $REPO" >&2
  echo "  expected tools/hermes-hosting-market-signal.js" >&2
  exit 1
fi

NODE="$(command -v node || true)"
if [[ -z "$NODE" ]]; then
  echo "ibm-yolo: node not found in PATH" >&2
  exit 1
fi

doctor() {
  local ok=1
  local bin_path resolved
  bin_path="$(command -v ibm-yolo 2>/dev/null || true)"
  resolved=""
  if [[ -n "$bin_path" && -L "$bin_path" ]]; then
    resolved="$(readlink "$bin_path" 2>/dev/null || true)"
  fi
  echo "=== ibm-yolo doctor ($(hostname -s 2>/dev/null || hostname)) ==="
  echo "layout=hermes-home (same family as grok-yolo / meta-yolo)"
  echo "hermes_home=$HERMES_HOME"
  echo "repo=$REPO"
  echo "revenue_dir=$REVENUE_DIR"
  echo "bin=${bin_path:-missing}${resolved:+ -> $resolved}"
  echo "node=$NODE ($($NODE -v 2>/dev/null || echo '?'))"
  for f in \
    tools/hermes-hosting-market-signal.js \
    tools/smart-ops-controller.js \
    tools/revenue-autonomous-loop.js \
    docs/ENTERPRISE-AGENT-SDLC-RELIABILITY.md; do
    if [[ -f "$REPO/$f" ]]; then
      echo "OK $f"
    else
      echo "MISS $f"
      ok=0
    fi
  done
  if [[ -d "$REVENUE_DIR" ]]; then
    echo "OK revenue_dir"
    local map
    map="$(ls -t "$REVENUE_DIR"/stripe-offer-map-*.tsv 2>/dev/null | head -1 || true)"
    if [[ -n "$map" ]]; then
      echo "OK stripe_map=$(basename "$map")"
      while IFS=$'\t' read -r offer url; do
        [[ -z "${url:-}" ]] && continue
        code="$(curl -sS -o /dev/null -w '%{http_code}' -L --max-time 12 "$url" 2>/dev/null || echo fail)"
        echo "  stripe $code $offer"
      done < <(awk -F'\t' 'NR>1{print $1"\t"$7}' "$map")
    else
      echo "WARN no stripe-offer-map-*.tsv"
    fi
  else
    echo "MISS revenue_dir"
    ok=0
  fi
  local uid
  uid="$(id -u)"
  for label in com.igor.smart-ops com.igor.revenue-autonomous-loop; do
    if launchctl print "gui/${uid}/${label}" >/dev/null 2>&1; then
      local last
      last="$(launchctl print "gui/${uid}/${label}" 2>/dev/null | awk -F'= ' '/last exit code/{print $2; exit}')"
      echo "OK launchd $label last_exit=${last:-?}"
    else
      echo "WARN launchd $label not loaded"
    fi
  done
  if command -v ibm-yolo >/dev/null 2>&1; then
    echo "OK path=$(command -v ibm-yolo)"
  else
    echo "WARN ibm-yolo not on PATH"
  fi
  if ((ok)); then
    echo "DOCTOR_OK"
    return 0
  fi
  echo "DOCTOR_FAIL"
  return 1
}

if ((DOCTOR)); then
  doctor
  exit $?
fi

cd "$REPO"

# Always capture JSON from the market-signal tool, then either print raw or a clear human summary.
run_preset_json() {
  local preset="$1"
  local args=(tools/hermes-hosting-market-signal.js --preset "$preset" --json)
  if ((APPLY)); then
    args+=(--apply-pipeline)
  fi
  "$NODE" "${args[@]}"
}

print_human_summary() {
  local payload="$1"
  local label="${2:-enterprise-sdlc}"
  "$NODE" -e '
const j = JSON.parse(process.argv[1] || "{}");
const label = process.argv[2] || "run";
const ok = !!j.ok;
const stripe = j.stripe && j.stripe.links ? j.stripe.links : {};
const okN = Object.values(stripe).filter(s => s && s.ok).length;
const total = Object.keys(stripe).length;
const pipe = j.pipeline || {};
const drafts = j.drafts || {};
const sig = j.signal || {};
const already = pipe.method === "already_present";
const cta = drafts.cta || "(no live CTA — check Stripe map)";
// Status first: do not make "already_present" look like a broken tool.
const statusLine = ok
  ? (already
      ? "ibm-yolo: OK (signal already loaded — this is working, not stuck)"
      : "ibm-yolo: OK (pipeline updated)")
  : "ibm-yolo: FAILED";
const lines = [
  "",
  statusLine,
  "────────────────────────────────────────",
  "preset:  " + label,
  "signal:  " + (sig.id || "(none)"),
  "source:  " + (sig.source || ""),
  "stripe:  " + okN + "/" + total + " payment links live",
  "pipeline:" + (already
    ? " already on board (safe re-run; no duplicate row)"
    : (pipe.method || (pipe.skipped ? "skipped" : "n/a")) +
      (pipe.prospect ? " → " + pipe.prospect : "")),
  "board:   " + (j.boardPath || "(none)"),
  "",
  "Buy link (live):",
  "  " + cta,
  "",
];
if (ok) {
  lines.push("What just happened:");
  lines.push("  ibm-yolo ran successfully. Exit code 0 means the CLI works.");
  if (already) {
    lines.push("  This market signal was already in the pipeline from an earlier run.");
    lines.push("  Re-running is fine — it will not create a second deal row.");
  } else if (pipe.ok) {
    lines.push("  New/updated pipeline row written for this signal.");
  } else {
    lines.push("  Pipeline not written (--no-apply or missing revenue data).");
  }
  lines.push("");
  lines.push("What ibm-yolo is for:");
  lines.push("  market signal + Stripe check + drafts + pipeline seed.");
  lines.push("  It does NOT send email/X by itself — that is the cash step after this.");
  lines.push("");
  lines.push("Real next action (not more ibm-yolo flags):");
  if (okN > 0) {
    lines.push("  Send the CTA above to a real prospect, or post the X draft on the board.");
  } else {
    lines.push("  Fix Stripe map — no live payment links.");
  }
  lines.push("  Full X + email drafts: " + (j.boardPath || "board path missing"));
  lines.push("");
  lines.push("Optional: ibm-yolo --doctor | --both | --smart-ops | --json");
  lines.push("");
} else {
  lines.push("Something failed. Run: ibm-yolo --doctor");
  lines.push("");
}
process.stdout.write(lines.join("\n") + "\n");
if (drafts.xReply) {
  process.stdout.write("── X draft (preview) ──\n");
  process.stdout.write(String(drafts.xReply).slice(0, 400) + (String(drafts.xReply).length > 400 ? "…\n" : "\n"));
  process.stdout.write("\n");
}
process.exit(ok ? 0 : 1);
' "$payload" "$label"
}


EXIT=0
if ((BOTH)); then
  hermes_out="$(run_preset_json hermes-hosted 2>/dev/null || echo '{"ok":false}')"
  ent_out="$(run_preset_json enterprise-sdlc 2>/dev/null || echo '{"ok":false}')"
  if ((JSON)); then
    "$NODE" -e '
      const h=JSON.parse(process.argv[1]||"{}");
      const e=JSON.parse(process.argv[2]||"{}");
      console.log(JSON.stringify({ok: !!(h.ok&&e.ok), hermes_hosted:h, enterprise_sdlc:e, command:"ibm-yolo --both"}, null, 2));
      process.exit((h.ok&&e.ok)?0:1);
    ' "$hermes_out" "$ent_out" || EXIT=1
  else
    print_human_summary "$hermes_out" "hermes-hosted" || EXIT=1
    print_human_summary "$ent_out" "enterprise-sdlc" || EXIT=1
  fi
else
  out="$(run_preset_json enterprise-sdlc 2>/dev/null || echo '{"ok":false}')"
  if ((JSON)); then
    printf '%s\n' "$out"
    echo "$out" | "$NODE" -e 'let s="";process.stdin.on("data",d=>s+=d);process.stdin.on("end",()=>{try{const j=JSON.parse(s);process.exit(j.ok?0:1)}catch{process.exit(1)}})' || EXIT=1
  else
    print_human_summary "$out" "enterprise-sdlc" || EXIT=1
  fi
fi

if ((SMART)); then
  if [[ -f "$REPO/tools/smart-ops-controller.js" ]]; then
    export SMART_OPS_MARKET_SIGNAL=1
    export REVENUE_AUTO_SEND="${REVENUE_AUTO_SEND:-1}"
    export REVENUE_NTFY_QUIET_NOOP="${REVENUE_NTFY_QUIET_NOOP:-1}"
    so="$("$NODE" tools/smart-ops-controller.js --json 2>/dev/null || echo '{}')"
    if ((JSON)); then
      echo "$so"
    else
      echo "=== smart-ops ==="
      echo "$so" | "$NODE" -e '
        let s=""; process.stdin.on("data",d=>s+=d); process.stdin.on("end",()=>{
          try {
            const j=JSON.parse(s);
            console.log("smart-ops: " + (j.ok ? "SUCCESS" : "FAILED") + "  durationMs=" + (j.durationMs||"?"));
            (j.actions||[]).forEach(a=>console.log("  • " + a));
          } catch { console.log(s.slice(0,500)); }
        });
      '
    fi
  fi
fi

exit "$EXIT"
