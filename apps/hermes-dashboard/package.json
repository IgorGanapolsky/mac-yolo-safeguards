{
  "name": "@hermes-mobile/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Secure desktop-first web dashboard for shared Hermes threads.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node src/cli.js",
    "test": "node --test test/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include='src/**/*.js' --test-coverage-lines=90 --test-coverage-functions=90 --test-coverage-branches=85 test/*.test.js",
    "test:e2e": "playwright test",
    "ci": "npm run test:coverage && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
