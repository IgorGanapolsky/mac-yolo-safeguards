# Server-side control-plane values. Never expose secrets with a NEXT_PUBLIC_ prefix.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=https://leash.dev/api/auth/callback
HERMES_CLOUD_RUNNER_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Direct Cloudflare deployment configuration. The D1 UUID is environment-specific.
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_CUSTOM_DOMAIN=leash.dev

# Connector-only variables stay on each paired Hermes machine and are never deployed to Cloudflare.
# HERMES_SESSION_GATEWAY_URL=http://127.0.0.1:8642
# HERMES_MODEL_GATEWAY_URL=http://127.0.0.1:4010
# HERMES_GATEWAY_API_KEY=
