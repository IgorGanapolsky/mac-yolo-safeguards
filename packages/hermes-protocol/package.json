{
  "name": "@hermes-mobile/protocol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Durable, idempotent thread event protocol shared by Hermes phone and web clients.",
  "engines": {
    "node": ">=22"
  },
  "exports": "./src/index.js",
  "types": "./index.d.ts",
  "files": [
    "src",
    "index.d.ts",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "test:e2e": "node --test test/e2e.two-client.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include='src/**/*.js' --test-coverage-lines=95 --test-coverage-functions=95 --test-coverage-branches=90",
    "ci": "npm run test:coverage && npm run test:e2e"
  }
}
