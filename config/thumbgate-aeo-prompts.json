{
  "schema": "thumbgate-aeo-prompts/v1",
  "version": "2026-07-23.1",
  "brand": "ThumbGate",
  "canonicalHost": "thumbgate.app",
  "baseUrl": "https://thumbgate.app",
  "cadence": "weekly",
  "monthlyBudgetUsd": 0.1,
  "queries": [
    {
      "id": "hermes-web-chat",
      "prompt": "How can I securely access and continue Hermes agent chats from a web browser?"
    },
    {
      "id": "hermes-mobile-phone",
      "prompt": "What is Hermes Mobile and how do I control a Hermes agent from my phone without inbound ports?"
    },
    {
      "id": "local-agent-failover",
      "prompt": "What is a safe way to continue a local AI agent task in the cloud when its computer goes offline?"
    }
  ],
  "technicalChecks": [
    {
      "id": "landing",
      "path": "/",
      "includes": [
        "application/ld+json",
        "FAQPage",
        "SoftwareApplication",
        "MobileApplication",
        "What is ThumbGate?",
        "What is Hermes Mobile?"
      ]
    },
    {
      "id": "robots",
      "path": "/robots.txt",
      "includes": ["https://thumbgate.app/sitemap.xml", "Disallow: /dashboard"]
    },
    {
      "id": "sitemap",
      "path": "/sitemap.xml",
      "includes": ["https://thumbgate.app/"]
    },
    {
      "id": "llms",
      "path": "/llms.txt",
      "includes": [
        "# Leash by ThumbGate",
        "https://thumbgate.app/",
        "Hermes Mobile",
        "https://thumbgate.app/go/android",
        "https://thumbgate.app/go/ios"
      ]
    },
    {
      "id": "ard",
      "path": "/.well-known/ai-catalog.json",
      "includes": ["specVersion", "1.0"]
    }
  ]
}
