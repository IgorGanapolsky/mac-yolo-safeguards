{
  "manifest_version": 3,
  "name": "Hermes Browser Bridge",
  "version": "0.2.0",
  "description": "Drive everyday Chrome tabs for Hermes via chrome.debugger (no restart) + local CDP bridge on 127.0.0.1:9222. Page content stays on-device.",
  "action": {
    "default_title": "Hermes Browser Bridge",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["debugger", "tabs", "storage"],
  "host_permissions": [
    "http://127.0.0.1:9222/*",
    "http://localhost:9222/*",
    "http://127.0.0.1:9223/*",
    "http://localhost:9223/*"
  ]
}
